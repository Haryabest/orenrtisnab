# ID счётчика Яндекс Метрики (только цифры, например 12345678)
# Можно задать здесь ИЛИ в админке: Сайт и SEO → Яндекс Метрика ID
# Достаточно одного способа; приоритет у значения из админки
VITE_YANDEX_METRIKA_ID=110818589
# --- Сервер ---
PORT=3001
NODE_ENV=production

# PostgreSQL (docker compose up -d). Без Docker сервер использует JSON-файлы в server/data/
DATABASE_URL=postgresql://orenrtisnab:orenrtisnab@localhost:5432/orenrtisnab

# Основной домен и поддомен админки
MAIN_DOMAIN=orenrtisnab.ru
ADMIN_SUBDOMAIN=admin.orenrtisnab.ru
# Включить HSTS/secure-cookies только ПОСЛЕ certbot (HTTPS). До SSL — false
ENABLE_HTTPS=false
# IP сервера — пока домен не подключён, сайт откроется по http://IP
# SERVER_IP=31.129.103.174

# Уведомления о заявках (оставьте пустым, чтобы отключить канал)
# Telegram: создайте бота через @BotFather, узнайте chat_id через getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# MAX: токен из dev.max.ru / MAX для бизнеса; укажите user_id ИЛИ chat_id
MAX_BOT_TOKEN=
MAX_USER_ID=
# MAX_CHAT_ID=

# Секрет для JWT (минимум 32 символа в production)
JWT_SECRET=change-me-to-a-long-random-secret-in-production

# Учётные данные админки
ADMIN_USERNAME=admin
# В production используйте надёжный пароль (мин. 12 символов)
# или bcrypt-хэш: ADMIN_PASSWORD=$2a$12$...
ADMIN_PASSWORD=admin12345
