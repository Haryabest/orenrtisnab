# Перенаправление HTTP → HTTPS и заголовки безопасности
# Для nginx / Apache / Cloudflare — настройте на хостинге

server {
    listen 80;
    server_name orenrtisnab.ru www.orenrtisnab.ru;
    return 301 https://orenrtisnab.ru$request_uri;
}

server {
    listen 443 ssl http2;
    server_name orenrtisnab.ru;

    root /var/www/orenrtisnab/dist;
    index index.html;

    # SSL-сертификат (Let's Encrypt / ваш хостинг)
    ssl_certificate     /etc/ssl/certs/orenrtisnab.crt;
    ssl_certificate_key /etc/ssl/private/orenrtisnab.key;
    ssl_protocols TLSv1.2 TLSv1.3;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "DENY" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|svg|webp|jpg|png|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
