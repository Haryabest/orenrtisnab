{
  "name": "orenrtisnab",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n site,server -c blue,green \"vite\" \"tsx watch --env-file=.env server/index.ts\"",
    "dev:admin": "concurrently -n admin,server -c magenta,green \"vite --config admin/vite.config.ts\" \"tsx watch --env-file=.env server/index.ts\"",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "build": "tsc -b && vite build && vite build --config admin/vite.config.ts",
    "build:site": "tsc -b && vite build",
    "build:admin": "vite build --config admin/vite.config.ts",
    "start": "node --env-file=.env --import tsx server/index.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@react-input/mask": "^2.0.4",
    "antd": "^6.5.1",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "framer-motion": "^12.42.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.13.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.20.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  },
  "browserslist": [
    "Chrome >= 87",
    "Edge >= 88",
    "Firefox >= 78",
    "Safari >= 14",
    "Yandex >= 21"
  ]
}
